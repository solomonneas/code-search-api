# Code Search API Configuration

# API key for protected endpoints. Leave unset to disable auth.
CODE_SEARCH_API_KEY=

# Root directory to scan for code repositories.
CODE_SEARCH_WORKSPACE=./repos

# Optional second root for reference docs or supporting material.
CODE_SEARCH_REFERENCE=

# SQLite database path.
CODE_SEARCH_DB=./code_index.db

# CORS origins. Use * for all, or comma-separated list.
CODE_SEARCH_CORS_ORIGINS=*

# Ollama connection.
OLLAMA_URL=http://localhost:11434

# Embedding model. See README for options and VRAM requirements.
# Recommended: qwen3-embedding:8b (~6GB VRAM, best quality)
# Lightweight:  nomic-embed-text (~300MB VRAM, fast)
CODE_SEARCH_EMBED_MODEL=qwen3-embedding:8b

# Summary model. Needs to be a capable code-reading model (14B+ local, or cloud).
# Current tested default: qwen3-coder-next:cloud.
# Best tested cloud fallback: kimi-k2.6:cloud.
# DeepSeek V4 Pro is available through Ollama, but should be benchmarked separately.
# See README for recommendations by VRAM budget and Ollama auth mode.
CODE_SEARCH_SUMMARY_MODEL=qwen3-coder-next:cloud
CODE_SEARCH_SUMMARY_FALLBACK=qwen3-coder-next:cloud

# Runtime tuning.
CODE_SEARCH_SUMMARY_WORKERS=4
CODE_SEARCH_DB_BATCH_SIZE=100
CODE_SEARCH_CACHE_TTL_SECONDS=3600
