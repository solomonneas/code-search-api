# Required for protected API endpoints. Leave unset to disable API-key auth.
CODE_SEARCH_API_KEY=change-me

# Code roots to index.
CODE_SEARCH_WORKSPACE=./repos
# Optional second root for reference docs or supporting code. Leave blank to disable.
CODE_SEARCH_REFERENCE=

# SQLite database location.
CODE_SEARCH_DB=./code_index.db

# CORS allowlist. Use * for all origins or provide a comma-separated list.
CODE_SEARCH_CORS_ORIGINS=*

# Ollama connection and models.
OLLAMA_URL=http://localhost:11434
CODE_SEARCH_EMBED_MODEL=nomic-embed-text
CODE_SEARCH_SUMMARY_MODEL=qwen2.5:14b
CODE_SEARCH_SUMMARY_FALLBACK=qwen2.5:14b

# Runtime tuning.
CODE_SEARCH_SUMMARY_WORKERS=4
CODE_SEARCH_DB_BATCH_SIZE=100
CODE_SEARCH_CACHE_TTL_SECONDS=3600

# Optional backup settings used by backup-db.sh.
CODE_SEARCH_BACKUP_DIR=./backups
CODE_SEARCH_MAX_BACKUPS=14
